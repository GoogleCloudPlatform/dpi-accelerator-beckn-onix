# =============================================================
# URGENT INPUT - REQUIRED FOR DEPLOYMENT
# =============================================================
GOOGLE_CLOUD_PROJECT="your-google-cloud-project-id"
REGION="us-central1"
APP_NAME="demo"

# (Optional) The GCS bucket to use for staging model artifacts.
# (RECOMMENDED) If not provided, it will be automatically derived/created as gs://${GOOGLE_CLOUD_PROJECT}-dpi-${APP_NAME}-bucket
# STAGING_BUCKET="gs://my-staging-bucket-name"

# =============================================================
# COMMON TUNABLES - QUICK CONFIGURATION
# =============================================================
# Session Storage Type: "agent-engine"(for Vertex AI session service)
# or "database" (for Cloud SQL) or "in-memory" (for local testing)
SESSION_DB_TYPE="agent-engine"

# Memory Configuration: Enable/Disable Long-Term Memory (Reasoning Engine)
ENABLE_LONG_TERM_MEMORY="true"

# Sub-agent orchestration: Define which sub-agents are enabled and how they are used
SUB_AGENTS_OF_ROOT_AGENT="agri.market_linkages,agri.loan_discovery,agri.mandi_prices,agri.govt_benefits,agri.soil_testing,agri.agri_inputs"
SUB_AGENTS_AS_TOOLS_OF_ROOT_AGENT="agri.biochar_advice,agri.weather_forecast,agri.pest_detection"

# =============================================================
# DATASTORE IMPORT CONFIGURATIONS
# =============================================================
# Map specific Agent strings to their target GCS buckets.
# These keys MUST match the exact sub-agent name (e.g. "agri.biochar_advice").
# The keys will be used to automatically synthesize environment variables.
# You can use paths and wildcards to target specific folders.
# Example: '{"agri.biochar_advice": "gs://my-bucket/biochar_files/*"}'
DATASTORE_IMPORTS='{}'

# Observability & Logging
LOG_LEVEL="INFO"
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY="TRUE"
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT="TRUE"

# =============================================================
# AGENT ENGINE INFRASTRUCTURE SETTINGS
# =============================================================

# Resource Allocation & Scaling
MIN_INSTANCES="1"
MAX_INSTANCES="10"
CONTAINER_CONCURRENCY="4"
CPU_LIMIT="4"
MEMORY_LIMIT="16Gi"

# =============================================================
# AGENT LLM & BEHAVIOR SETTINGS
# =============================================================
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_LOCATION="global"

ROOT_AGENT_LLM_MODEL="gemini-2.5-flash"
ROOT_AGENT_LLM_TEMPERATURE="0.1"

ROOT_AGENT_LIVE_LLM_MODEL="gemini-live-2.5-flash"
ROOT_AGENT_LIVE_LLM_TEMPERATURE="0.1"

GOOGLE_SEARCH_LLM_MODEL="gemini-2.5-flash"
GOOGLE_SEARCH_LLM_TEMPERATURE="0.1"
GOOGLE_SEARCH_LIVE_LLM_MODEL="gemini-2.5-flash"
GOOGLE_SEARCH_LIVE_LLM_TEMPERATURE="0.1"

SUB_AGENTS_LLM_MODEL="gemini-2.5-flash"
SUB_AGENTS_LLM_TEMPERATURE="0.1"
SUB_AGENTS_LIVE_LLM_MODEL="gemini-live-2.5-flash"
SUB_AGENTS_LIVE_LLM_TEMPERATURE="0.1"

ALLOW_GOOGLE_SEARCH_FOR_GENERAL_QNA="true"
VOICE_NAME="Aoede"
MAX_LLM_CALLS_PER_QUERY="20"

# Sleep seconds for live messages yield
LIVE_MESSAGES_YIELD_SLEEP_SECONDS=0.01  # 10 milliseconds

# =============================================================
# MEMORY & CONTEXT CONFIGURATIONS
# =============================================================
MEMORY_BANK_EMBEDDING_MODEL="gemini-embedding-001"
MEMORY_BANK_GENERATION_MODEL="gemini-2.5-flash"
MEMORY_BANK_MEMORY_TTL="2592000s"

CONTEXT_COMPACTION_ENABLED="TRUE"
CONTEXT_COMPACTION_INTERVAL="5"
CONTEXT_OVERLAP_SIZE="1"

# =============================================================
# SESSION & DATABASE (Placeholder - Extracted by Installer)
# =============================================================
SESSION_DB_POOL_SIZE="25"
SESSION_DB_MAX_OVERFLOW="30"
SESSION_DB_POOL_RECYCLE="1800"
SESSION_DB_POOL_TIMEOUT="30"

# =============================================================
# EXTERNAL TOOLS & INTEGRATIONS
# =============================================================
MAX_SEARCH_RESULTS="1"
SEARCH_TIMEOUT_SECONDS="15"
# Enables Google Cloud service account impersonation to hit the adapter securely.
SHOULD_ADD_OAUTH_BEARER_TOKEN="FALSE"
# The service account that the application should impersonate to hit the adapter.
GOOGLE_ADAPTER_INVOKER_SERVICE_ACCOUNT="your-adapter-invoker-sa@your-project.iam.gserviceaccount.com"
# The required audience string for the generated auth token
# for the adapter to be called.
GOOGLE_ADAPTER_AUDIENCE="adapter_full_domain/caller/api"

# (Optional) The Pub/Sub topic ID for the Adapter. If not provided, the installer tries to resolve it from ONIX outputs.
# ADAPTER_TOPIC_ID="projects/your-project/topics/adapter-topic"

# Redis connection settings (Populated by installer)
# REDIS_HOST="localhost"
# REDIS_PORT="6379"

# Mandi Price API
MANDI_API_URL="https://farmservicesapi.agribazaar.com/search"
MANDI_API_KEY="your-mandi-key"

# Audio Settings
AUDIO_SAMPLE_RATE="16000"
AUDIO_SAMPLE_WIDTH="2"
AUDIO_N_CHANNELS="1"

# =============================================================
# NETWORK DOMAIN SETTINGS
# =============================================================

BECKN_ADAPTER_DOMAINS_CONFIG='{
  "agri.market_linkages": {
    "gateway_url": "https://your-adapter-url.com/bap/caller/",
    "bap_id": "gemini-agent.bap.uag.gov.in",
    "bap_uri": "https://your-adapter-url.com/bap/receiver/",
    "domain": "agri-procurement"
  },
  "agri.loan_discovery": {
    "gateway_url": "https://your-adapter-url.com/bap/caller/",
    "bap_id": "gemini-agent.bap.uag.gov.in",
    "bap_uri": "https://your-adapter-url.com/bap/receiver/",
    "domain": "agri-credit"
  },
  "agri.govt_benefits": {
    "gateway_url": "https://your-adapter-url.com/bap/caller/",
    "bap_id": "gemini-agent.bap.uag.gov.in",
    "bap_uri": "https://your-adapter-url.com/bap/receiver/",
    "domain": "agri-schemes",
    "bpp_id": "ona.haqdarshak.com",
    "bpp_uri": "https://adapter.haqdarshak.com/bpp/receiver/"
  },
  "agri.agri_inputs": {
    "gateway_url": "https://your-adapter-url.com/bap/caller/",
    "bap_id": "gemini-agent.bap.uag.gov.in",
    "bap_uri": "https://your-adapter-url.com/bap/receiver/",
    "domain": "agri-inputs",
    "bpp_id": "ona.haqdarshak.com",
    "bpp_uri": "https://adapter.haqdarshak.com/bpp/receiver/"
  }
}'
