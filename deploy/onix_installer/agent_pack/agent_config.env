# =============================================================
# REPO CLONING (Optional)
# =============================================================
# Repositories for dynamic cloning if not present locally
# AGENT_BLUEPRINT_REPO="https://github.com/google/dpi-agent-blueprint.git"
# AGENT_BLUEPRINT_TAG="main"

# =============================================================
# URGENT INPUT - REQUIRED FOR DEPLOYMENT
# =============================================================
PROJECT_ID="your-google-cloud-project-id"
REGION="us-central1"
APP_NAME="demo"

# (Optional) The GCS bucket to use for staging model artifacts.
# (RECOMMENDED) If not provided, it will be automatically derived as gs://${PROJECT_ID}-dpi-${APP_NAME}-bucket
# STAGING_BUCKET="gs://my-staging-bucket-name"

# =============================================================
# COMMON TUNABLES - QUICK CONFIGURATION
# =============================================================
# Session Storage Type: "database" (for Cloud SQL) or "in-memory" (for local testing)
SESSION_DB_TYPE="agent-engine"

# Memory Configuration: Enable/Disable Long-Term Memory (Reasoning Engine)
ENABLE_LONG_TERM_MEMORY="true"

# Sub-agent orchestration: Define which sub-agents are enabled and how they are used
SUB_AGENTS_OF_ROOT_AGENT="agri.market_linkages,agri.loan_discovery,agri.mandi_prices,agri.govt_benefits,agri.soil_testing,agri.agri_inputs"
SUB_AGENTS_AS_TOOLS_OF_ROOT_AGENT="agri.biochar_advice,agri.weather_forecast,agri.pest_detection,agri.soil_testing,agri.agri_inputs"

# Observability & Logging
LOG_LEVEL="INFO"
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY="TRUE"
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT="TRUE"

# =============================================================
# AGENT ENGINE INFRASTRUCTURE SETTINGS
# =============================================================

# GCS directory inside STAGING_BUCKET for artifacts
GCS_DIR_NAME="agent-engine-artifacts"

# Resource Allocation & Scaling
MIN_INSTANCES="1"
MAX_INSTANCES="10"
CONTAINER_CONCURRENCY="3"
CPU_LIMIT="1"
MEMORY_LIMIT="4Gi"

# =============================================================
# AGENT LLM & BEHAVIOR SETTINGS
# =============================================================
ROOT_AGENT_LLM_MODEL="gemini-2.5-flash"
ROOT_AGENT_LLM_TEMPERATURE="0.1"

ROOT_AGENT_LIVE_LLM_MODEL="gemini-live-2.5-flash"
ROOT_AGENT_LIVE_LLM_TEMPERATURE="0.1"

GOOGLE_SEARCH_LLM_MODEL="gemini-2.5-flash"
GOOGLE_SEARCH_LLM_TEMPERATURE="0.1"
GOOGLE_SEARCH_LIVE_LLM_MODEL="gemini-2.5-flash"
GOOGLE_SEARCH_LIVE_LLM_TEMPERATURE="0.1"

SUB_AGENTS_LLM_MODEL="gemini-2.5-flash"
SUB_AGENTS_LLM_TEMPERATURE="0.1"
SUB_AGENTS_LIVE_LLM_MODEL="gemini-live-2.5-flash"
SUB_AGENTS_LIVE_LLM_TEMPERATURE="0.1"

ALLOW_GOOGLE_SEARCH_FOR_GENERAL_QNA="true"
VOICE_NAME="Aoede"
MAX_LLM_CALLS_PER_QUERY="20"

# =============================================================
# MEMORY & CONTEXT CONFIGURATIONS
# =============================================================
MEMORY_BANK_EMBEDDING_MODEL="gemini-embedding-001"
MEMORY_BANK_GENERATION_MODEL="gemini-2.5-flash"
MEMORY_BANK_MEMORY_TTL="2592000s"

CONTEXT_COMPACTION_ENABLED="TRUE"
CONTEXT_COMPACTION_INTERVAL="5"
CONTEXT_OVERLAP_SIZE="1"

# =============================================================
# SESSION & DATABASE (Placeholder - Extracted by Installer)
# =============================================================
SESSION_DB_POOL_SIZE="25"
SESSION_DB_MAX_OVERFLOW="30"
SESSION_DB_POOL_RECYCLE="1800"
SESSION_DB_POOL_TIMEOUT="30"

# =============================================================
# EXTERNAL TOOLS & INTEGRATIONS
# =============================================================
MAX_SEARCH_RESULTS="1"
SEARCH_TIMEOUT_SECONDS="5"
SHOULD_ADD_OAUTH_BEARER_TOKEN="FALSE"

# Redis connection settings (Extracted by installer if using PSC)
REDIS_HOST="localhost"
REDIS_PORT="6379"

# Mandi Price API
MANDI_API_URL="https://farmservicesapi.agribazaar.com/search"
MANDI_API_KEY="your-mandi-key"

# Audio Settings
AUDIO_SAMPLE_RATE="16000"
AUDIO_SAMPLE_WIDTH="2"
AUDIO_N_CHANNELS="1"

# =============================================================
# NETWORK DOMAIN SETTINGS (AGRI)
# =============================================================

AGRI-PROCUREMENT.gateway_url="https://onix-adapter-image-903496459467.asia-east1.run.app/bap/caller/"
AGRI-PROCUREMENT.bap_id="gemini-agent.bap.uag.gov.in"
AGRI-PROCUREMENT.bap_uri="https://onix-adapter-image-903496459467.asia-east1.run.app/bap/receiver/"
AGRI-PROCUREMENT.domain="agri-procurement"
AGRI-PROCUREMENT.country="IND"
AGRI-PROCUREMENT.city="std:080"
AGRI-PROCUREMENT.version="1.0.0"
AGRI-PROCUREMENT.ttl="PT30S"

AGRI-LOAN.gateway_url="https://onix-adapter-image-903496459467.asia-east1.run.app/bap/caller/"
AGRI-LOAN.bap_id="gemini-agent.bap.uag.gov.in"
AGRI-LOAN.bap_uri="https://onix-adapter-image-903496459467.asia-east1.run.app/bap/receiver/"
AGRI-LOAN.domain="agri-credit"
AGRI-LOAN.country="IND"
AGRI-LOAN.city="std:080"
AGRI-LOAN.version="1.0.0"
AGRI-LOAN.ttl="PT30S"

AGRI-SCHEME.gateway_url="https://onix-adapter-image-903496459467.asia-east1.run.app/bap/caller/"
AGRI-SCHEME.bap_id="gemini-agent.bap.uag.gov.in"
AGRI-SCHEME.bap_uri="https://onix-adapter-image-903496459467.asia-east1.run.app/bap/receiver/"
AGRI-SCHEME.domain="agri-schemes"
AGRI-SCHEME.version="1.0.0"
AGRI-SCHEME.ttl="PT30S"
AGRI-SCHEME.bpp_id="ona.haqdarshak.com"
AGRI-SCHEME.bpp_uri="https://adapter.haqdarshak.com/bpp/receiver/"

