# Core Standalone Configuration
PROJECT_ID="your-google-cloud-project-id"
REGION="us-central1"
APP_NAME="demo"
AGENT_IMAGE_URL="gcr.io/your-project/repo/agent:latest"

# -------------------------------------------------------------
# DYNAMIC AGENT VARIABLES (Passed to Cloud Run)
# -------------------------------------------------------------

# ** AGENT LLM MODEL SETTINGS **
ROOT_AGENT_LLM_MODEL="gemini-2.5-flash"
ROOT_AGENT_LLM_TEMPERATURE="0.1"

ROOT_AGENT_LIVE_LLM_MODEL="gemini-live-2.5-flash"
ROOT_AGENT_LIVE_LLM_TEMPERATURE="0.1"

GOOGLE_SEARCH_LLM_MODEL="gemini-2.5-flash"
GOOGLE_SEARCH_LLM_TEMPERATURE="0.1"
GOOGLE_SEARCH_LIVE_LLM_MODEL="gemini-2.5-flash"
GOOGLE_SEARCH_LIVE_LLM_TEMPERATURE="0.1"

SUB_AGENTS_LLM_MODEL="gemini-2.5-flash"
SUB_AGENTS_LLM_TEMPERATURE="0.1"
SUB_AGENTS_LIVE_LLM_MODEL="gemini-live-2.5-flash"
SUB_AGENTS_LIVE_LLM_TEMPERATURE="0.1"

# ** AGENT CONFIGURATIONS **
SUB_AGENTS_OF_ROOT_AGENT="agri.market_linkages,agri.loan_discovery,agri.mandi_prices"
SUB_AGENTS_AS_TOOLS_OF_ROOT_AGENT="agri.weather_forecast,agri.govt_benefits,agri.pest_detection"
ALLOW_GOOGLE_SEARCH_FOR_GENERAL_QNA="true"
VOICE_NAME="Aoede"
MAX_LLM_CALLS_PER_QUERY="20"

# ** MEMORY BANK CONFIGURATIONS **
ENABLE_LONG_TERM_MEMORY="false"
GOOGLE_CLOUD_MEMORY_SERVICE_LOCATION="us-central1"
MEMORY_BANK_EMBEDDING_MODEL="gemini-embedding-001"
MEMORY_BANK_GENERATION_MODEL="gemini-2.5-flash"
MEMORY_BANK_MEMORY_TTL="2592000s"
AGENT_ENGINE_ID="your-agent-engine-id"

# ** OBSERVABILITY CONFIGURATIONS **
OTEL_MONITORING_ENABLED="TRUE"
OTEL_OBSERVABILITY_LOG_NAME="open-networks-agent-traces"
OTEL_TRACE_LATENCY="TRUE"
OTEL_TRACE_TOKENS="TRUE"
OTEL_LOG_EXECUTOR_WORKERS="2"

# ** CONTEXT COMPACTION **
CONTEXT_COMPACTION_ENABLED="TRUE"
CONTEXT_COMPACTION_INTERVAL="5"
CONTEXT_OVERLAP_SIZE="1"

# ** SESSION SERVICE CONFIGURATIONS **
SESSION_DB_TYPE="in-memory"
SESSION_DB_URL=""
SESSION_DB_POOL_SIZE="25"
SESSION_DB_MAX_OVERFLOW="30"
SESSION_DB_POOL_RECYCLE="1800"
SESSION_DB_POOL_TIMEOUT="30"

# ** TOOLS SPECIFIC CONFIGURATIONS **
REDIS_HOST="localhost"
REDIS_PORT="6379"
MAX_SEARCH_RESULTS="1"
SEARCH_TIMEOUT_SECONDS="5"
SHOULD_ADD_OAUTH_BEARER_TOKEN="TRUE"

# Network specific settings
ONEST.gateway_url="https://onix-adapter-image-903496459467.asia-east1.run.app/bap/caller/"
ONEST.bap_id="test_bap"
ONEST.bap_uri="https://onix-adapter-image-903496459467.asia-east1.run.app/bap/receiver/"
ONEST.country="IND"
ONEST.city="std:080"
ONEST.domain="ONEST"
ONEST.version="1.0.0"
ONEST.ttl="PT30S"
ONEST.bpp_id="test_bpp"
ONEST.bpp_uri="https://onix-adapter-image-903496459467.asia-east1.run.app/bpp/receiver/"

ONDC.gateway_url="https://onix-adapter-image-903496459467.asia-east1.run.app/bap/caller/"
